<script setup>
defineProps({ title: String })
const open = ref(true)
function toggle() { open.value = !open.value }
</script>

<template>
  <div class="panel">
    <div class="panel-header" @click="toggle">
      {{ title }} <span v-show="open">[Hide]</span><span v-show="!open">[Show]</span>
    </div>
    <div class="panel-body" v-show="open">
      <slot />
    </div>
  </div>
</template>

<style scoped>
.panel { border: 1px solid #ccc; border-radius: 4px; margin: 1rem 0; }
.panel-header { padding: 0.75rem; background: #f5f5f5; cursor: pointer; font-weight: bold; }
.panel-body { padding: 0.75rem; }
</style>
